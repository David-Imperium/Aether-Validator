{
  "_comment": "Aether mandatory validation hook - Linux/Mac version. Rename this to settings.json on Unix systems",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Create",
        "hooks": [
          {
            "type": "command",
            "command": "\"$FACTORY_PROJECT_DIR\"/.factory/hooks/aether-validate.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
