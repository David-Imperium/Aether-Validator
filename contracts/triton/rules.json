{
  "name": "Triton Private Rules",
  "version": "1.0.0",
  "description": "Project-specific validation rules for Triton engine",
  "rules": {
    "forbidden": [
      {
        "id": "TRITON001",
        "pattern": "print(",
        "message": "Use Triton::Logger instead of print",
        "severity": "warning",
        "suggestion": "Use TRITON_INFO(), TRITON_WARN(), or TRITON_ERROR()"
      },
      {
        "id": "TRITON002",
        "pattern": "console.log",
        "message": "Use Triton::Logger instead of console.log",
        "severity": "warning",
        "suggestion": "Use TRITON_INFO() or TRITON_DEBUG()"
      },
      {
        "id": "TRITON003",
        "pattern": "dbg!(",
        "message": "Use Triton::Logger instead of dbg!",
        "severity": "error",
        "suggestion": "Use triton::log::debug!() for debug logging"
      },
      {
        "id": "TRITON004",
        "pattern": "println!(",
        "message": "Use Triton::Logger instead of println!",
        "severity": "error",
        "suggestion": "Use triton::log::info!() for logging"
      },
      {
        "id": "TRITON005",
        "pattern": "eprintln!(",
        "message": "Use Triton::Logger instead of eprintln!",
        "severity": "warning",
        "suggestion": "Use triton::log::error!() for error logging"
      },
      {
        "id": "TRITON010",
        "pattern": "unwrap()",
        "message": "Avoid unwrap() in production - use proper error handling",
        "severity": "error",
        "suggestion": "Use ? operator or Triton::Result<T>"
      },
      {
        "id": "TRITON011",
        "pattern": "panic!(",
        "message": "Panic is forbidden in Triton - use Result",
        "severity": "error",
        "suggestion": "Return Triton::Error or use ? operator"
      },
      {
        "id": "TRITON020",
        "pattern": "unsafe",
        "message": "Unsafe code requires safety documentation",
        "severity": "warning",
        "suggestion": "Add SAFETY: comment explaining why unsafe is safe"
      },
      {
        "id": "TRITON021",
        "pattern": "TODO",
        "message": "TODOs must be tracked",
        "severity": "info",
        "suggestion": "Link to issue tracker or add FIXME with deadline"
      }
    ],
    "required": [
      {
        "id": "TRITON100",
        "pattern": "//! ",
        "message": "Module-level documentation required",
        "severity": "warning",
        "file_pattern": "src/**/*.rs"
      },
      {
        "id": "TRITON101",
        "pattern": "#[derive(Debug)]",
        "message": "Structs should derive Debug for logging",
        "severity": "info",
        "file_pattern": "src/**/*.rs"
      }
    ],
    "naming": [
      {
        "kind": "function",
        "pattern": "^[a-z][a-z0-9_]*$",
        "message": "Function names must be snake_case"
      },
      {
        "kind": "struct",
        "pattern": "^[A-Z][a-zA-Z0-9]*$",
        "message": "Struct names must be PascalCase"
      },
      {
        "kind": "enum",
        "pattern": "^[A-Z][a-zA-Z0-9]*$",
        "message": "Enum names must be PascalCase"
      },
      {
        "kind": "constant",
        "pattern": "^[A-Z][A-Z0-9_]*$",
        "message": "Constants must be SCREAMING_SNAKE_CASE"
      },
      {
        "kind": "trait",
        "pattern": "^[A-Z][a-zA-Z0-9]*$",
        "message": "Trait names must be PascalCase"
      }
    ],
    "structure": [
      {
        "requirement": "max_file_lines",
        "max": 500,
        "message": "File exceeds 500 lines - consider splitting into modules"
      },
      {
        "requirement": "max_function_lines",
        "max": 50,
        "message": "Function exceeds 50 lines - consider extracting helpers"
      }
    ]
  }
}
